{
  "name": "expectations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:local": "npm run dev -w apps/api & npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "test": "npm run test -w apps/api && npm run test -w apps/web",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript-eslint": "^8.59.3"
  }
}
